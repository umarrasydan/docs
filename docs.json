{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Xendit Documentation",
  "colors": {
    "primary": "#1662EE",
    "light": "#03CF99",
    "dark": "#1662EE"
  },
  "favicon": "/xendit-favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "guides/migration/xen-bri-to-h2h",
              "guides/migration/xen-bri-sdk-to-c2c"
            ]
          }
        ]
      },
      {
        "tab": "Wizard",
        "groups": [
          {
            "group": "Quickstart Wizard",
            "pages": [
              "guides/getting-started/quickstart"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/index"
            ]
          },
          {
            "group": "Terminal API (H2H)",
            "openapi": "openapi-spec.yaml",
            "pages": [
              "api-reference/terminal-api/introduction",
              "api-reference/terminal-api/concepts",
              "POST /v1/terminal/sessions",
              "GET /v1/terminal/sessions/{id}",
              "POST /v1/terminal/sessions/{id}/retry",
              "GET /v1/terminal/payments/{id}",
              "POST /v1/terminal/payments/{id}/void",
              "POST /v1/terminal/commands",
              "api-reference/terminal-api/callbacks",
              "api-reference/terminal-api/errors"
            ]
          },
          {
            "group": "Terminal API (C2C)",
            "openapi": "openapi-spec-c2c.yaml",
            "pages": [
              "api-reference/c2c/introduction",
              "POST /commands/pay",
              "POST /commands/cancel",
              "POST /commands/receipt",
              "POST /commands/settlement",
              "POST /commands/histories"
            ]
          }
        ]
      },
      {
        "tab": "SDK & Libraries",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "sdk/index"
            ]
          },
          {
            "group": "Terminal Gateway",
            "pages": [
              "sdk/gateway/introduction",
              "sdk/gateway/app-configuration"
            ]
          },
          {
            "group": "Terminal SDK",
            "pages": [
              "sdk/terminal-sdk/index",
              {
                "group": "H2H",
                "pages": [
                  "sdk/h2h/introduction",
                  "sdk/h2h/android-sdk/index",
                  "sdk/h2h/ios-sdk/index"
                ]
              },
              {
                "group": "C2C",
                "pages": [
                  "sdk/c2c/introduction",
                  "sdk/c2c/android-sdk/index",
                  "sdk/c2c/ios-sdk/index"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://docs.xendit.co",
          "icon": "/xendit-favicon.ico"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:inpersonpayments@xendit.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.xendit.co"
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "curl",
        "php",
        "java",
        "go",
        "python",
        "javascript",
        "ruby"
      ],
      "defaults": "all"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/xendit",
      "github": "https://github.com/xendit",
      "linkedin": "https://linkedin.com/company/xendit"
    }
  }
}